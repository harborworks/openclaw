# Harbor Host Configuration
# Copy to .env.host and fill in values

# Remote harbor backend
HARBOR_API_URL=http://192.168.1.101:3001/api
HARBOR_API_KEY=dev-api-key

# OpenClaw gateway
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_IMAGE=openclaw:local
GATEWAY_PORT=18789

# Daemon
DAEMON_PORT=4747

# OpenClaw config/workspace paths on host
OPENCLAW_CONFIG_DIR=~/.openclaw
OPENCLAW_WORKSPACE_DIR=~/.openclaw/workspace
