# Harbor Dev Stack — runs alongside production on the same host.
# Copy to .env.host and adjust values as needed.
#
# Usage:
#   COMPOSE_PROJECT_NAME=harbor-dev docker compose \
#     -f docker-compose.host.yml -f docker-compose.dev.yml \
#     --env-file .env.host up -d

# Convex backend (dev instance)
CONVEX_URL=
HARBOR_ID=
HARBOR_API_KEY=

# OpenClaw gateway
OPENCLAW_GATEWAY_TOKEN=

# Ports — offset from defaults to avoid conflicts with production
GATEWAY_PORT=18790
DAEMON_PORT=4748
FRONTEND_PORT=5173

# Data directories — separate from production
OPENCLAW_CONFIG_DIR=~/harbor-dev/config
OPENCLAW_WORKSPACE_DIR=~/harbor-dev/workspaces

# Docker socket GID (run: stat -c '%g' /var/run/docker.sock)
DOCKER_GID=998

# Sandbox
SANDBOX_MODE=all
SANDBOX_IMAGE=harbor-sandbox:latest
