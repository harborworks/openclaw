{
  "commands": {
    "restart": true
  },
  "gateway": {
    "auth": {
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "mode": "local"
  },
  "auth": {
    "profiles": {
      "anthropic:default": {
        "provider": "anthropic",
        "mode": "token"
      }
    }
  },
  "agents": {
    "defaults": {
      "heartbeat": {
        "every": "0m"
      },
      "model": {
        "primary": "anthropic/claude-opus-4-6"
      }
    }
  }
}
