{
  "commands": {
    "restart": true
  },
  "gateway": {
    "auth": {
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "mode": "local"
  },
  "auth": {
    "profiles": {
      "anthropic:default": {
        "provider": "anthropic",
        "mode": "token"
      }
    }
  },
  "agents": {
    "defaults": {
      "heartbeat": {
        "every": "0m"
      },
      "model": {
        "primary": "opus"
      },
      "models": {
        "anthropic/claude-opus-4-6": {
          "alias": "opus"
        }
      }
    },
    "list": [
      {
        "id": "main",
        "workspace": "${HOME}/workspaces/main"
      }
    ]
  },
  "channels": {
    "telegram": {
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "enabled": true,
      "dmPolicy": "pairing",
      "groupPolicy": "allowlist",
      "streamMode": "block"
    }
  },
  "plugins": {
    "entries": {
      "telegram": {
        "enabled": true
      }
    }
  },
  "tools": {
    "sandbox": {
      "tools": {
        "allow": [
          "exec",
          "process",
          "read",
          "write",
          "edit",
          "sessions_list",
          "sessions_history",
          "sessions_send",
          "sessions_spawn",
          "session_status",
          "web_search"
        ]
      }
    },
    "web": {
      "search": {
        "apiKey": "${BRAVE_SEARCH_API_KEY}",
        "provider": "brave"
      }
    }
  }
}
